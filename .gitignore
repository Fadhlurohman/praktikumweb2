# CodeIgniter 4 standard .gitignore

# Sensitive files containing credentials
.env

# Composer dependencies
/vendor/

# PHPUnit and testing
/tests/_support/_generated/

# Writable directories (logs, cache, sessions, etc.)
/writable/cache/*
/writable/debugbar/*
/writable/logs/*
/writable/session/*
/writable/uploads/*
!/writable/cache/index.html
!/writable/debugbar/index.html
!/writable/logs/index.html
!/writable/session/index.html
!/writable/uploads/index.html
!/writable/index.html
!/writable/.htaccess

# User upload directories
/public/gambar/*
!/public/gambar/.gitkeep
